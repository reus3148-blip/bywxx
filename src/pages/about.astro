---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`소개 · ${SITE_TITLE}`} description="bywxx에 대한 소개" />
	</head>
	<body>
		<Header />
		<main>
			<div class="container about-wrap">
				<section class="profile">
					<div class="avatar">b</div>
					<h1>bywxx</h1>
					<p class="bio">
						배우고 만든 것들을 천천히 기록합니다.
					</p>
					<div class="links">
						<a href="https://github.com/reus3148-blip" target="_blank" rel="noopener">GitHub</a>
						<span class="sep">·</span>
						<a href="/rss.xml">RSS</a>
					</div>
				</section>

				<section class="card">
					<h2>관심사</h2>
					<ul>
						<li>웹 개발 — React, HTML/CSS, 그리고 Astro</li>
						<li>새로운 기술을 배우고 직접 만들어 보기</li>
						<li>가벼운 글로 정리하기</li>
					</ul>
				</section>

				<section class="card">
					<h2>이 블로그</h2>
					<ul>
						<li>Astro 6 + Vercel로 배포</li>
						<li>글은 마크다운으로 작성, GitHub에 영구 보관</li>
						<li>Tistory 스타일을 좋아해서 그쪽 느낌으로 직접 꾸몄어요</li>
					</ul>
				</section>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.about-wrap {
		max-width: 720px;
		padding-top: 56px;
		padding-bottom: 40px;
	}
	.profile {
		text-align: center;
		padding-bottom: 40px;
		margin-bottom: 32px;
		border-bottom: 1px solid var(--line);
	}
	.avatar {
		width: 80px;
		height: 80px;
		border-radius: 50%;
		background: linear-gradient(135deg, var(--accent), #6b9eff);
		color: #fff;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 2rem;
		font-weight: 700;
		margin: 0 auto 16px;
	}
	.profile h1 {
		margin: 0 0 8px;
		font-size: 1.8rem;
	}
	.bio {
		margin: 0 0 16px;
		color: var(--muted);
	}
	.links { color: var(--muted); font-size: 0.92rem; }
	.links a { color: var(--ink-soft); }
	.links a:hover { color: var(--accent); }
	.sep { margin: 0 8px; color: var(--muted-soft); }

	.card {
		padding: 24px 28px;
		background: var(--bg-soft);
		border: 1px solid var(--line);
		border-radius: var(--radius-lg);
		margin-bottom: 16px;
	}
	.card h2 {
		margin: 0 0 12px;
		font-size: 1.1rem;
	}
	.card ul {
		margin: 0;
		padding-left: 1.2em;
	}
	.card li {
		margin-bottom: 6px;
		color: var(--ink-soft);
	}
	.card li::marker {
		color: var(--muted-soft);
	}
</style>
