---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const categoryMap = new Map<string, number>();
for (const post of posts) {
	const cat = post.data.category || '일상';
	categoryMap.set(cat, (categoryMap.get(cat) || 0) + 1);
}
const categories = [...categoryMap.entries()].sort((a, b) => b[1] - a[1]);

const tagSet = new Set<string>();
for (const post of posts) {
	for (const t of post.data.tags || []) tagSet.add(t);
}
const tags = [...tagSet];
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`블로그 · ${SITE_TITLE}`} description={`${SITE_TITLE}의 모든 글`} />
	</head>
	<body>
		<Header />
		<main>
			<div class="container blog-layout">
				<section class="post-list-col">
					<header class="page-head">
						<h1>블로그</h1>
						<p class="page-desc">총 {posts.length}개의 글</p>
					</header>

					<ul class="post-list">
						{posts.map((post) => (
							<li class="post-item">
								<a href={`/blog/${post.id}/`}>
									{post.data.heroImage && (
										<div class="thumb">
											<Image width={400} height={240} src={post.data.heroImage} alt="" />
										</div>
									)}
									<div class="body">
										<div class="meta">
											<span class="cat">{post.data.category || '일상'}</span>
											<span class="dot">·</span>
											<FormattedDate date={post.data.pubDate} />
										</div>
										<h2 class="title">{post.data.title}</h2>
										<p class="excerpt">{post.data.description}</p>
										{post.data.tags && post.data.tags.length > 0 && (
											<div class="tags">
												{post.data.tags.map((t) => (
													<span class="tag">#{t}</span>
												))}
											</div>
										)}
									</div>
								</a>
							</li>
						))}
					</ul>
				</section>

				<aside class="sidebar">
					<div class="widget">
						<h3>카테고리</h3>
						<ul class="cat-list">
							<li><a href="/blog/" class="active"><span>전체</span><b>{posts.length}</b></a></li>
							{categories.map(([name, count]) => (
								<li>
									<a href={`/blog/?category=${encodeURIComponent(name)}`}>
										<span>{name}</span><b>{count}</b>
									</a>
								</li>
							))}
						</ul>
					</div>

					{tags.length > 0 && (
						<div class="widget">
							<h3>태그</h3>
							<div class="tag-cloud">
								{tags.map((t) => (
									<a class="tag-pill" href={`/blog/?tag=${encodeURIComponent(t)}`}>#{t}</a>
								))}
							</div>
						</div>
					)}
				</aside>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.blog-layout {
		display: grid;
		grid-template-columns: 1fr 260px;
		gap: 56px;
		padding-top: 40px;
		padding-bottom: 40px;
	}
	.page-head {
		margin-bottom: 32px;
		padding-bottom: 20px;
		border-bottom: 1px solid var(--line);
	}
	.page-head h1 {
		font-size: 2rem;
		margin: 0 0 6px;
	}
	.page-desc {
		margin: 0;
		color: var(--muted);
		font-size: 0.95rem;
	}

	.post-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
	}
	.post-item {
		padding: 28px 0;
		border-bottom: 1px solid var(--line);
	}
	.post-item:last-child {
		border-bottom: none;
	}
	.post-item a {
		display: grid;
		grid-template-columns: 1fr 200px;
		gap: 24px;
		color: var(--ink-soft);
		align-items: start;
	}
	.post-item .thumb {
		overflow: hidden;
		border-radius: var(--radius);
		aspect-ratio: 5 / 3;
		background: var(--line-soft);
		order: 2;
	}
	.post-item .thumb :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 0;
		transition: transform 0.3s ease;
	}
	.post-item a:hover .thumb :global(img) {
		transform: scale(1.04);
	}
	.body { order: 1; min-width: 0; }
	.meta {
		display: flex;
		align-items: center;
		gap: 6px;
		color: var(--muted);
		font-size: 0.85rem;
		margin-bottom: 8px;
	}
	.cat {
		color: var(--accent);
		font-weight: 600;
	}
	.dot { color: var(--muted-soft); }
	.title {
		margin: 0 0 8px;
		font-size: 1.25rem;
		color: var(--ink);
		line-height: 1.4;
		transition: color 0.15s ease;
	}
	.post-item a:hover .title {
		color: var(--accent);
	}
	.excerpt {
		margin: 0 0 10px;
		color: var(--muted);
		font-size: 0.93rem;
		line-height: 1.6;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.tags { display: flex; gap: 8px; flex-wrap: wrap; }
	.tag { color: var(--muted); font-size: 0.82rem; }

	/* sidebar */
	.sidebar { display: flex; flex-direction: column; gap: 28px; }
	.widget {
		padding: 20px;
		background: var(--bg-soft);
		border: 1px solid var(--line);
		border-radius: var(--radius-lg);
	}
	.widget h3 {
		margin: 0 0 14px;
		font-size: 0.9rem;
		color: var(--muted);
		font-weight: 600;
		letter-spacing: 0.02em;
		text-transform: uppercase;
	}
	.cat-list { list-style: none; padding: 0; margin: 0; }
	.cat-list li { margin: 0; }
	.cat-list a {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 8px 0;
		color: var(--ink-soft);
		font-size: 0.95rem;
	}
	.cat-list a:hover, .cat-list a.active { color: var(--accent); }
	.cat-list a b {
		font-weight: 500;
		color: var(--muted-soft);
		font-size: 0.85rem;
	}
	.tag-cloud { display: flex; gap: 8px; flex-wrap: wrap; }
	.tag-pill {
		display: inline-block;
		padding: 4px 10px;
		background: var(--bg);
		border: 1px solid var(--line);
		border-radius: 999px;
		font-size: 0.82rem;
		color: var(--ink-soft);
	}
	.tag-pill:hover {
		background: var(--accent-soft);
		border-color: var(--accent-soft);
		color: var(--accent);
	}

	@media (max-width: 900px) {
		.blog-layout {
			grid-template-columns: 1fr;
			gap: 32px;
		}
		.sidebar { order: -1; }
		.widget { padding: 16px; }
	}
	@media (max-width: 600px) {
		.post-item a {
			grid-template-columns: 1fr;
		}
		.post-item .thumb {
			order: 1;
			aspect-ratio: 16 / 9;
		}
		.body { order: 2; }
	}
</style>
