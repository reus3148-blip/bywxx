---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & {
	prev?: CollectionEntry<'blog'> | null;
	next?: CollectionEntry<'blog'> | null;
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	category = '일상',
	tags = [],
	prev,
	next,
} = Astro.props;
---

<html lang="ko">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main>
			<article class="post">
				<header class="post-head container">
					<a href={`/blog/?category=${encodeURIComponent(category)}`} class="cat-link">
						{category}
					</a>
					<h1>{title}</h1>
					{description && <p class="description">{description}</p>}
					<div class="meta">
						<span>bywxx</span>
						<span class="dot">·</span>
						<FormattedDate date={pubDate} />
						{updatedDate && (
							<>
								<span class="dot">·</span>
								<span class="updated">수정 <FormattedDate date={updatedDate} /></span>
							</>
						)}
					</div>
				</header>

				{heroImage && (
					<div class="hero container-wide">
						<Image width={1200} height={630} src={heroImage} alt="" />
					</div>
				)}

				<div class="post-body container">
					<div class="prose">
						<slot />
					</div>

					{tags.length > 0 && (
						<div class="tags">
							{tags.map((t) => (
								<a class="tag-pill" href={`/blog/?tag=${encodeURIComponent(t)}`}>#{t}</a>
							))}
						</div>
					)}

					{(prev || next) && (
						<nav class="post-nav">
							{prev ? (
								<a class="nav-item prev" href={`/blog/${prev.id}/`}>
									<span class="label">← 이전 글</span>
									<span class="t">{prev.data.title}</span>
								</a>
							) : <span class="nav-item disabled" />}
							{next ? (
								<a class="nav-item next" href={`/blog/${next.id}/`}>
									<span class="label">다음 글 →</span>
									<span class="t">{next.data.title}</span>
								</a>
							) : <span class="nav-item disabled" />}
						</nav>
					)}
				</div>
			</article>
		</main>
		<Footer />

		<style>
			.post-head {
				padding-top: 56px;
				padding-bottom: 32px;
				max-width: var(--content);
			}
			.cat-link {
				display: inline-block;
				font-size: 0.85rem;
				color: var(--accent);
				font-weight: 600;
				margin-bottom: 12px;
			}
			.post-head h1 {
				font-size: 2.4rem;
				margin: 0 0 16px;
				line-height: 1.3;
				color: var(--ink);
			}
			.description {
				margin: 0 0 20px;
				color: var(--muted);
				font-size: 1.08rem;
				line-height: 1.6;
			}
			.meta {
				display: flex;
				align-items: center;
				gap: 8px;
				color: var(--muted);
				font-size: 0.9rem;
			}
			.dot { color: var(--muted-soft); }
			.updated { font-style: italic; }

			.container-wide {
				max-width: 1200px;
				margin: 0 auto 40px;
				padding: 0 24px;
			}
			.hero :global(img) {
				display: block;
				width: 100%;
				height: auto;
				border-radius: var(--radius-lg);
				box-shadow: var(--shadow-md);
			}

			.post-body {
				max-width: var(--content);
				padding-bottom: 40px;
			}

			.tags {
				display: flex;
				gap: 8px;
				flex-wrap: wrap;
				margin: 40px 0;
				padding: 24px 0;
				border-top: 1px solid var(--line);
				border-bottom: 1px solid var(--line);
			}
			.tag-pill {
				display: inline-block;
				padding: 6px 12px;
				background: var(--line-soft);
				border-radius: 999px;
				font-size: 0.85rem;
				color: var(--ink-soft);
			}
			.tag-pill:hover {
				background: var(--accent-soft);
				color: var(--accent);
			}

			.post-nav {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 16px;
				margin-top: 40px;
			}
			.nav-item {
				display: flex;
				flex-direction: column;
				padding: 18px 20px;
				border: 1px solid var(--line);
				border-radius: var(--radius-lg);
				background: var(--bg);
				min-height: 84px;
				color: var(--ink-soft);
				transition: border-color 0.15s ease, background 0.15s ease;
			}
			.nav-item:hover {
				border-color: var(--accent);
				background: var(--accent-soft);
			}
			.nav-item.disabled {
				visibility: hidden;
			}
			.nav-item .label {
				font-size: 0.82rem;
				color: var(--muted);
				margin-bottom: 6px;
			}
			.nav-item .t {
				font-weight: 600;
				color: var(--ink);
				line-height: 1.4;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			.nav-item.next {
				text-align: right;
			}

			@media (max-width: 720px) {
				.post-head { padding-top: 32px; padding-bottom: 24px; }
				.post-head h1 { font-size: 1.8rem; }
				.description { font-size: 1rem; }
				.container-wide { padding: 0 16px; margin-bottom: 28px; }
				.post-nav { grid-template-columns: 1fr; }
				.nav-item.next { text-align: left; }
			}
		</style>
	</body>
</html>
