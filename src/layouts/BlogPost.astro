---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="ko">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
				padding: 0;
			}
			.hero-image {
				width: 100%;
				max-width: 1020px;
				margin: 2em auto 0;
				padding: 0 1em;
			}
			.hero-image img {
				display: block;
				width: 100%;
				height: auto;
				margin: 0 auto;
				border-radius: 14px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 2.5em;
				padding: 2.5em 0 1.5em;
				text-align: center;
				line-height: 1.2;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.title h1 {
				margin: 0.2em 0 0.4em 0;
				font-size: 2.6em;
				letter-spacing: -0.02em;
			}
			.description {
				margin: 0 auto;
				max-width: 580px;
				color: rgb(var(--gray));
				font-size: 1.05em;
				line-height: 1.6;
			}
			.date {
				display: inline-flex;
				align-items: center;
				gap: 0.6em;
				margin-bottom: 0.2em;
				color: rgb(var(--gray));
				font-size: 0.9em;
				letter-spacing: 0.02em;
			}
			.date .dot {
				width: 4px;
				height: 4px;
				border-radius: 50%;
				background: rgb(var(--gray-light));
			}
			.last-updated-on {
				font-style: italic;
			}
			@media (max-width: 720px) {
				.title {
					padding: 1.5em 0 1em;
					margin-bottom: 1.8em;
				}
				.title h1 {
					font-size: 2em;
				}
				.description {
					font-size: 1em;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				{
					heroImage && (
						<div class="hero-image">
							<Image width={1020} height={510} src={heroImage} alt="" />
						</div>
					)
				}
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<>
										<span class="dot" />
										<span class="last-updated-on">
											수정 <FormattedDate date={updatedDate} />
										</span>
									</>
								)
							}
						</div>
						<h1>{title}</h1>
						{description && <p class="description">{description}</p>}
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
